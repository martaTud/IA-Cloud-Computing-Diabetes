    "# ─── IaaS: ALMACENAMIENTO DE DATOS CLÍNICOS ───\n",
    "# En un sistema real esto sería Amazon S3, Azure Blob Storage o Google Cloud Storage\n",
    "# Aquí simulamos el mismo concepto: guardar y recuperar datos estructurados\n",
    "\n",
    "print(\"=\"*55)\n",
    "print(\"☁️  SIMULACIÓN DE IaaS — Almacenamiento Cloud\")\n",
    "print(\"=\"*55)\n",
    "print(\"Equivalente real: Amazon S3 / Azure Blob Storage\\n\")\n",
    "\n",
    "# ── Creamos un 'bucket' (carpeta) para almacenar registros clínicos ──\n",
    "os.makedirs('cloud_storage/pacientes', exist_ok=True)\n",
    "os.makedirs('cloud_storage/informes', exist_ok=True)\n",
    "\n",
    "# ── Función para subir un expediente al 'cloud' ──\n",
    "def subir_expediente(id_paciente, datos_clinicos):\n",
    "    \"\"\"Simula subir un expediente a un bucket S3\"\"\"\n",
    "    datos_clinicos['timestamp'] = datetime.now().isoformat()\n",
    "    datos_clinicos['id_paciente'] = id_paciente\n",
    "    \n",
    "    # En S3 real sería: s3.put_object(Bucket='hospital-data', Key=f'pacientes/{id_paciente}.json')\n",
    "    ruta = f'cloud_storage/pacientes/{id_paciente}.json'\n",
    "    with open(ruta, 'w') as f:\n",
    "        json.dump(datos_clinicos, f, indent=2, ensure_ascii=False)\n",
    "    \n",
    "    print(f\"  ✅ Expediente subido → cloud_storage/pacientes/{id_paciente}.json\")\n",
    "    return ruta\n",
    "\n",
    "# ── Función para recuperar un expediente ──\n",
    "def recuperar_expediente(id_paciente):\n",
    "    \"\"\"Simula descargar un expediente de S3\"\"\"\n",
    "    ruta = f'cloud_storage/pacientes/{id_paciente}.json'\n",
    "    if os.path.exists(ruta):\n",
    "        with open(ruta, 'r') as f:\n",
    "            return json.load(f)\n",
    "    return None\n",
