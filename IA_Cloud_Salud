    "# ─── PaaS: SIMULACIÓN DE API REST DE DIAGNÓSTICO ───\n",
    "# En un PaaS real (Heroku, Azure App Service, Google App Engine)\n",
    "# tendrías este servicio desplegado y accesible desde cualquier lugar del mundo\n",
    "\n",
    "print(\"=\"*55)\n",
    "print(\"☁️  SIMULACIÓN DE PaaS — API de Diagnóstico\")\n",
    "print(\"=\"*55)\n",
    "print(\"Equivalente real: Microservicio desplegado en Azure App Service\\n\")\n",
    "\n",
    "# ── Simulamos el backend de una API REST de diagnóstico ──\n",
    "def api_diagnostico(payload):\n",
    "    \"\"\"\n",
    "    Simula una llamada POST a:\n",
    "    POST https://api.hospital-cloud.com/v1/diagnostico\n",
    "    Content-Type: application/json\n",
    "    \"\"\"\n",
    "    # Validación de entrada (como haría una API real)\n",
    "    campos_requeridos = ['glucosa', 'imc', 'edad']\n",
    "    for campo in campos_requeridos:\n",
    "        if campo not in payload:\n",
    "            return {\"error\": f\"Campo requerido: {campo}\", \"status\": 400}\n",
    "    \n",
    "    glucosa = payload['glucosa']\n",
    "    imc = payload['imc']\n",
    "    edad = payload['edad']\n",
    "    presion = payload.get('presion_arterial', 70)\n",
    "    \n",
    "    # Lógica de scoring clínico simplificada\n",
    "    riesgo = 0\n",
    "    factores = []\n",
    "    \n",
    "    if glucosa > 126:  factores.append(f\"Glucosa elevada ({glucosa} mg/dL)\"); riesgo += 40\n",
    "    elif glucosa > 100: factores.append(f\"Glucosa prediabética ({glucosa} mg/dL)\"); riesgo += 20\n",
    "    \n",
    "    if imc > 30:  factores.append(f\"Obesidad (IMC {imc})\"); riesgo += 25\n",
    "    elif imc > 25: factores.append(f\"Sobrepeso (IMC {imc})\"); riesgo += 12\n",
    "    \n",
    "    if edad > 45:  factores.append(f\"Edad de riesgo ({edad} años)\"); riesgo += 20\n",
    "    elif edad > 35: factores.append(f\"Edad moderada ({edad} años)\"); riesgo += 10\n",
    "    \n",
    "    if presion > 80: factores.append(f\"Presión elevada ({presion} mmHg)\"); riesgo += 15\n",
    "    \n",
    "    riesgo = min(riesgo, 100)\n",
    "    nivel = \"ALTO\" if riesgo >= 60 else \"MODERADO\" if riesgo >= 30 else \"BAJO\"\n",
    "    \n",
    "    return {\n",
    "        \"status\": 200,\n",
    "        \"request_id\": f\"REQ-{abs(hash(str(payload))) % 100000:05d}\",\n",
    "        \"timestamp\": datetime.now().isoformat(),\n",
    "        \"resultado\": {\n",
    "            \"riesgo_porcentaje\": riesgo,\n",
    "            \"nivel_riesgo\": nivel,\n",
    "            \"factores_detectados\": factores,\n",
    "            \"recomendacion\": \"Consulta urgente con endocrinólogo\" if nivel==\"ALTO\" else\n",
    "                             \"Seguimiento en 3 meses\" if nivel==\"MODERADO\" else\n",
    "                             \"Revisión anual rutinaria\"\n",
    "        }\n",
    "    }\n",
    "\n",
    "# ── Llamamos a la API con diferentes pacientes ──\n",
    "casos = [\n",
    "    {\"nombre\": \"Paciente A\", \"glucosa\": 148, \"imc\": 33.6, \"edad\": 50, \"presion_arterial\": 85},\n",
    "    {\"nombre\": \"Paciente B\", \"glucosa\": 89,  \"imc\": 22.5, \"edad\": 28, \"presion_arterial\": 65},\n",
    "    {\"nombre\": \"Paciente C\", \"glucosa\": 115, \"imc\": 27.0, \"edad\": 42, \"presion_arterial\": 78},\n",
    "]\n",
    "\n",
    "for caso in casos:\n",
    "    nombre = caso.pop('nombre')\n",
    "    print(f\"📡 POST /api/v1/diagnostico  →  {nombre}\")\n",
    "    \n",
    "    respuesta = api_diagnostico(caso)\n",
    "    r = respuesta['resultado']\n",
    "    emoji = \"🔴\" if r['nivel_riesgo']==\"ALTO\" else \"🟡\" if r['nivel_riesgo']==\"MODERADO\" else \"🟢\"\n",
    "    \n",
    "    print(f\"   {emoji} Riesgo: {r['riesgo_porcentaje']}% — {r['nivel_riesgo']}\")\n",
    "    print(f\"   📋 {r['recomendacion']}\")\n",
    "    if r['factores_detectados']:\n",
    "        print(f\"   ⚠️  Factores: {', '.join(r['factores_detectados'])}\")\n",
